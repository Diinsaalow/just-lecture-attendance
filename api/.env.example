MONGODB_URI=mongodb://127.0.0.1:27017/lecture-attendance

# Required for auth (see docs/module-auth.md)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m

# Admin self-registration: set ALLOW_ADMIN_REGISTER=true and send header
# x-admin-registration-key matching ADMIN_REGISTRATION_KEY when registering with role admin
ALLOW_ADMIN_REGISTER=false
ADMIN_REGISTRATION_KEY=
